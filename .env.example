# Copy to .env.local (gitignored) and fill in. NEVER commit real values.

# --- Public, safe to ship in the browser (Vite exposes VITE_* to the client) ---
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# --- Secrets: server/Edge-Function/CLI only. Do NOT prefix with VITE_ ---
# The service_role key bypasses RLS — keep it off the client entirely.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# For the AI menu generator Edge Function (set later via `supabase secrets set`).
ANTHROPIC_API_KEY="sk-ant-..."

# --- MCP server (agent access) ---
# The email you sign into the app with — log_day / get_stats / set_targets act as
# this user. Needs SUPABASE_SERVICE_ROLE_KEY above. See docs/mcp.md.
CUCINA_USER_EMAIL="you@email.com"
